{
  "name": "frontend",
  "private": true,
  "version": "1.6.3",
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-sw.js && vite",
    "build": "node scripts/generate-sw.js && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "vite preview --port $PORT --host",
    "prepare": "test -f node_modules/.bin/husky && husky || echo \"husky skipped\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "VITE_ENABLE_ENCRYPTION=true playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "firebase": "^12.10.0",
    "firebase-functions": "^7.2.5",
    "html-to-image": "^1.11.13",
    "i18next": "^25.8.11",
    "i18next-browser-languagedetector": "^8.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.18.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx}": "eslint --fix"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
