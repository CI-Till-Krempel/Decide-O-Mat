service cloud.firestore {
  match /databases/{database}/documents {
    match /decisions/{decisionId} {
      // All authenticated users (including anonymous) may read decisions.
      // Anonymous sign-in is enforced client-side, so this effectively
      // requires the user to have loaded the app.
      allow read: if request.auth != null;
      allow write: if false; // Only manageable via Cloud Functions

      match /finalVotes/{userId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      match /arguments/{argumentId} {
        allow read: if request.auth != null;
        allow write: if false;

        match /votes/{userId} {
          allow read: if request.auth != null;
          allow write: if false;
        }
      }

      match /participants/{userId} {
          allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/decisions/$(decisionId)).data.ownerId == request.auth.uid);
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
